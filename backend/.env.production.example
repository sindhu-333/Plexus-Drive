# ==================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==================================
# Copy this to your hosting platform's environment variables section
# DO NOT commit actual values to Git!

# ===== DATABASE =====
# Get this from your Neon/Supabase dashboard
DATABASE_URL=postgresql://username:password@host.neon.tech/plexus_db

# OR use individual settings (if not using DATABASE_URL)
# DB_HOST=your-database-host.com
# DB_PORT=5432
# DB_NAME=plexus_db
# DB_USER=your_username
# DB_PASSWORD=your_password

# ===== SERVER =====
PORT=5000
NODE_ENV=production

# ===== FRONTEND =====
# Your deployed frontend URL (e.g., https://plexus-drive.netlify.app)
FRONTEND_URL=https://your-frontend-url.netlify.app

# ===== SECURITY =====
# Generate a strong random string for JWT
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===== EMAIL (Gmail SMTP) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com

# ===== DROPBOX =====
# Get these from your Dropbox App Console
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REFRESH_TOKEN=your-dropbox-refresh-token

# ===== OPTIONAL: ngrok (only for local development with external access) =====
# NGROK_FRONTEND_URL=https://your-frontend.ngrok.io
# NGROK_BACKEND_URL=https://your-backend.ngrok.io

# ===== OPTIONAL: Email-specific URL (for email links) =====
# EMAIL_FRONTEND_URL=https://your-domain.com
